module flopr32(input  logic   clk, en, 
                 input  logic [31:0] d1,d2
                 output logic [31:0] q1,q2);

  always_ff @(posedge clk)
    if (en)   
      begin
        q1 <= d1;
        q2 <= d2;
      end
    else  
      begin
        q1 <= q1;
        q2 <= q2;
      end
endmodule
